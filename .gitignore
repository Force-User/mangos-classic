#
# NOTE! Don't add files that are generated in specific
# subdirectories here. Add them in the ".gitignore" file
# in that subdirectory instead.
#
# NOTE! Please use 'git-ls-files -i --exclude-standard'
# command after changing this file, to see if there are
# any tracked files which get ignored after the change.
#
# Normal rules
#
.*
*.o
*.o.*
*.so
*.so.dbg
*.bin
*.gz
# my
/build
/run/contrib
/run/_deps
/run/dep
/run/x64
/run/src/framework
/run/src/game/game.dir
/run/src/mangosd/mangosd.dir
/run/src/modules
*.obj
*.tlog
*.vcxproj
*.vcxproj.filters
*.lib
*.exp
*.log
*.pdb
*.pch
*.res
*.slnx
*.dist
*.recipe
*.ilk
#
# Top-level generic files
#
bin
build
build_linux
tags
TAGS
win
!.gitignore
!.gitattributes
!.travis.yml

#
# Build generated files
#
autom4te.cache

#
# Editors / debuggers / other output files
#
*~
*.bak
*.orig
*.patch
callgrind.out.*
nbproject/
.idea/
cmake-build-*/

#
# Git stuff
!.github/
# stgit directories
patches-*

#
# VS binaries output
#
bin/*

#
# VS temporary files
#
*.ncb
*.suo
*.sdf
*.opensdf
*.sln.cache
*.vsp
ipch
*.user
*.opendb
*.VC.db

#
# CMake temporary files
#
CMakeFiles
CMakeCache.txt
cmake_install.cmake

#
# OS specific
#
# MacOS
.DS_Store

#
# Special exceptions
#

# recastnavigation directory needs exception
!dep/recastnavigation/RecastDemo/Build/
/_build/

#
# Module files
#
src/modules/
